# Local development example using the production Suno wrapper endpoint.
# This file is not loaded automatically by Next.js. Copy the values into your local `.env` when needed.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/music_platform?schema=public"
REDIS_URL="redis://localhost:6379"
SUNO_COOKIE=""
SUNO_API_BASE_URL="https://suno.songsai.org"
MUSIC_PROVIDER_MODE="suno"
APP_URL="http://localhost:3000"
AUTH_SECRET="replace-with-a-long-random-secret"
