generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 사용자 권한 구분
enum UserRole {
  USER
  DEVELOPER
  ADMIN
}

/// 무료/유료 크레딧 종류
enum CreditKind {
  FREE
  PAID
}

/// 개별 크레딧 원장 상태
enum CreditGrantStatus {
  ACTIVE
  CONSUMED
  EXPIRED
}

/// 음악 생성 상태
enum MusicStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

/// 영상 렌더링 상태
enum VideoStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

/// 포인트 로그 유형
enum TransactionType {
  DEPOSIT
  USAGE
  REFUND
  ADJUSTMENT
}

/// 포인트 로그 처리 결과
enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

/// 작업 큐 대상 구분
enum JobTargetType {
  MUSIC
  VIDEO
}

/// 작업 종류
enum JobType {
  MUSIC_GENERATION
  VIDEO_RENDER
}

/// 큐 상태
enum QueueStatus {
  QUEUED
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

/// 입금 요청 상태
enum DepositRequestStatus {
  PENDING
  AUTO_MATCHED
  APPROVED
  REJECTED
  CANCELLED
}

/// 서비스 사용자. freeCredits / paidCredits 는 조회 성능용 캐시 필드다.
model User {
  id             String        @id @default(cuid())
  email          String        @unique
  googleId       String?       @unique
  passwordHash   String
  freeCredits    Int           @default(0)
  paidCredits    Int           @default(0)
  tier           String?
  role           UserRole      @default(USER)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  musics         Music[]
  transactions   Transaction[]
  generationJobs GenerationJob[]
  creditGrants   CreditGrant[]
  createdCoupons Coupon[]      @relation("CouponCreator")
  couponUses     CouponRedemption[]
  depositRequests DepositRequest[]
}

/// 생성된 음악 트랙 단위 레코드. 같은 요청에서 나온 곡은 requestGroupId로 묶는다.
model Music {
  id             String          @id @default(cuid())
  userId         String
  requestGroupId String?
  lyrics         String
  stylePrompt    String
  provider       String
  providerTaskId String?         @unique
  mp3Url         String?
  isBonusTrack   Boolean         @default(false)
  bonusUnlockedAt DateTime?
  status         MusicStatus     @default(QUEUED)
  duration       Int?
  errorMessage   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  videos         Video[]
  generationJobs GenerationJob[]

  @@index([userId, createdAt])
  @@index([requestGroupId, createdAt])
  @@index([status])
}

/// 향후 MP4/자막 합성용 결과물
model Video {
  id             String          @id @default(cuid())
  musicId        String
  mp4Url         String?
  bgImageUrl     String?
  srtUrl         String?
  status         VideoStatus     @default(QUEUED)
  errorMessage   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  music          Music           @relation(fields: [musicId], references: [id], onDelete: Cascade)
  generationJobs GenerationJob[]

  @@index([musicId, createdAt])
  @@index([status])
}

/// 포인트 입출금 회계 로그
model Transaction {
  id           String             @id @default(cuid())
  userId       String
  amount       Int
  creditKind   CreditKind?
  type         TransactionType
  status       TransactionStatus  @default(COMPLETED)
  balanceAfter Int
  memo         String?
  approvedBy   String?
  createdAt    DateTime           @default(now())

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type, status])
}

/// 실제 사용 가능한 크레딧 원장. 만료/환불/남은 수량을 grant 단위로 관리한다.
model CreditGrant {
  id              String            @id @default(cuid())
  userId          String
  creditKind      CreditKind
  amount          Int
  remainingAmount Int
  expiresAt       DateTime
  lastUsedAt      DateTime?
  status          CreditGrantStatus @default(ACTIVE)
  source          String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, creditKind, status])
  @@index([expiresAt, status])
}

/// 비동기 작업 기록. 나중에 워커 분리 시에도 그대로 활용할 수 있게 설계했다.
model GenerationJob {
  id           String         @id @default(cuid())
  userId       String
  musicId      String?
  videoId      String?
  targetType   JobTargetType
  jobType      JobType
  queueStatus  QueueStatus    @default(QUEUED)
  attemptCount Int            @default(0)
  payload      Json?
  result       Json?
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  music        Music?         @relation(fields: [musicId], references: [id], onDelete: Cascade)
  video        Video?         @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([queueStatus, jobType])
  @@index([musicId])
  @@index([videoId])
}

model Coupon {
  id            String             @id @default(cuid())
  code          String             @unique
  amount        Int
  remainingUses Int
  maxUses       Int
  isActive      Boolean            @default(true)
  createdById   String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  createdBy     User               @relation("CouponCreator", fields: [createdById], references: [id], onDelete: Cascade)
  redemptions   CouponRedemption[]

  @@index([isActive, createdAt])
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  createdAt DateTime @default(now())

  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
  @@index([userId, createdAt])
}

model DepositRequest {
  id                    String               @id @default(cuid())
  userId                String
  requestedAmount       Int
  requestedCredits      Int
  depositorName         String
  bankName              String
  accountNumberSnapshot String
  status                DepositRequestStatus @default(PENDING)
  autoMatchedAt         DateTime?
  matchedNotificationId String?
  approvedBy            String?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  memo                  String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([requestedAmount, status])
  @@index([depositorName])
}
