# Local development example using the production SONGS API wrapper endpoint.
# This file is not loaded automatically by Next.js. Copy the values into your local `.env` when needed.
# For AI auto-lyrics experiments, temporarily switch `SONGS_API_BASE_URL`
# to `https://dev-suno.songsai.org` after the separate test wrapper is ready.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/music_platform?schema=public"
REDIS_URL="redis://localhost:6379"
SONGS_COOKIE=""
SONGS_API_BASE_URL="https://suno.songsai.org"
MUSIC_PROVIDER_MODE="songs"
APP_URL="http://localhost:3000"
AUTH_SECRET="replace-with-a-long-random-secret"
